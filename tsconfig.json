{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "moduleResolution": "Node16",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "./dist"
    },
    "include": [
        "./**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}